# Vite / React (see vite.config.ts)
# Base URL of the Laravel API (no trailing slash) — same origin path is /api
# Example: http://127.0.0.1:8000/api  or  http://localhost/driveflow/backend/public/api
VITE_API_BASE=

# Demo mode — when "true", the SPA falls back to its in-browser localStorage
# (`erpApi`) for any module not yet wired to the real backend. When "false"
# or unset, demo fallbacks render an empty/explanatory state instead of
# fake data. Default: false (production posture).
VITE_DEMO_MODE=false
VITE_ALLOW_MOCK_FALLBACK=false

# Executive dashboard KPIs & charts (requires trusted backend metrics). Default off.
VITE_ENABLE_REAL_DASHBOARD=false

VITE_SHOW_EXPERIMENTAL=false

GEMINI_API_KEY=
