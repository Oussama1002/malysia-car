# DriveFlow — Template d'environnement Production
#
# Copier vers backend/.env sur le serveur de production.
# NE JAMAIS commiter ce fichier avec de vraies valeurs remplies.
# Les secrets doivent provenir d'un vault (AWS Secrets Manager, HashiCorp Vault,
# variables CI/CD chiffrées, etc.).
#
# Note: Les commentaires doivent être sur leur propre ligne.
# Les commentaires inline (valeur= # commentaire) peuvent causer des problèmes
# avec certains outils de déploiement — éviter.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="DriveFlow"
APP_ENV=production
APP_DEBUG=false

# REQUIS: php artisan key:generate --show
# Le résultat commence par base64:
APP_KEY=

APP_URL=https://api.driveflow.yourdomain.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# info pendant les premières 48h, puis warning
LOG_LEVEL=warning
# Nombre de fichiers journaliers à conserver (daily channel)
LOG_MAX_FILES=30

# ── Base de données ───────────────────────────────────────────────────────────
DB_CONNECTION=mysql
# Utiliser l'IP privée ou socket Unix pour MySQL sur le même host
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=driveflow_db
# Utilisateur dédié, PAS root
DB_USERNAME=driveflow_user
# REQUIS: mot de passe fort et aléatoire
DB_PASSWORD=
# Collation explicite — évite les problèmes d'encodage avec les accents/caractères arabes
DB_COLLATION=utf8mb4_unicode_ci

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.driveflow.yourdomain.com
SESSION_SECURE_COOKIE=true
# Protège contre les attaques CSRF cross-site
SESSION_SAME_SITE=lax

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Nombre de rounds bcrypt — 12 minimum en production
BCRYPT_ROUNDS=12

# ── Proxy / HTTPS (CRITIQUE si l'app est derrière Nginx/Apache/CDN) ──────────
# Sans ceci: APP_URL génère des URLs http://, Sanctum peut refuser les requêtes HTTPS
# Valeur: IP du proxy, range CIDR, ou * (moins sécurisé)
TRUSTED_PROXIES=127.0.0.1
TRUSTED_HOSTS=api.driveflow.yourdomain.com,app.driveflow.yourdomain.com

# ── Cache & Queue ─────────────────────────────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Storage ───────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# Pour S3 (recommandé en production pour les documents KYC et PDFs):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1
# AWS_BUCKET=driveflow-uploads
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Mail ──────────────────────────────────────────────────────────────────────
# Ne PAS utiliser "log" en production — les mails ne seront pas envoyés
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.yourmailprovider.com
MAIL_PORT=587
# REQUIS
MAIL_USERNAME=
# REQUIS
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@driveflow.yourdomain.com
MAIL_FROM_NAME="DriveFlow"

# ── Sanctum / CORS ────────────────────────────────────────────────────────────
# Doit correspondre EXACTEMENT à l'origine du frontend (sans trailing slash)
SANCTUM_STATEFUL_DOMAINS=app.driveflow.yourdomain.com
FRONTEND_URL=https://app.driveflow.yourdomain.com

# ── Signature électronique ────────────────────────────────────────────────────
# Options: internal | yousign | docusign
SIGNATURE_PROVIDER=internal
SIGNATURE_ALLOW_INTERNAL_OUTSIDE_DEV=true
SIGNATURE_INTERNAL_OTP_LOG=false

# Yousign (décommenter et remplir pour activer):
# SIGNATURE_PROVIDER=yousign
# YOUSIGN_BASE_URL=https://api.yousign.app/v3
# YOUSIGN_API_KEY=
# YOUSIGN_WEBHOOK_SECRET=

# DocuSign (décommenter et remplir pour activer):
# SIGNATURE_PROVIDER=docusign
# DOCUSIGN_BASE_URL=https://www.docusign.net/restapi
# DOCUSIGN_API_KEY=
# DOCUSIGN_WEBHOOK_SECRET=

# ── GPS Provider ──────────────────────────────────────────────────────────────
# GPS_PROVIDER=teltonika
# GPS_WEBHOOK_KEY=

# ── Broadcasting (notifications temps réel) ───────────────────────────────────
BROADCAST_CONNECTION=log

# Pusher/Reverb pour le temps réel (décommenter pour activer):
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=eu

# ── Monitoring (fortement recommandé en production) ───────────────────────────
# Sentry pour le tracking d'erreurs:
# SENTRY_LARAVEL_DSN=https://xxx@sentry.io/yyy

# Slack pour les alertes critiques:
# LOG_SLACK_WEBHOOK_URL=

# ── Maintenance ───────────────────────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file
