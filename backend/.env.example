APP_NAME="DriveFlow API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Public URL of this Laravel app (e.g. php artisan serve --port=8000)
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production schema: import `driveflow_db.sql` into `driveflow_db` (see docs/DATABASE-LOCAL.md).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=driveflow_db
DB_USERNAME=root
DB_PASSWORD=

# Local dev without MySQL:
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SPA (Vite) origin for Sanctum cookie auth if you use session-based SPA login
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000
FRONTEND_URL=http://127.0.0.1:3000

# Notifications — in-app + queued e-mail / SMS deliveries (see config/notifications.php)
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_QUEUE=default
NOTIFICATION_MAX_DELIVERY_ATTEMPTS=3
SMS_PROVIDER=log
SMS_API_KEY=
SMS_SENDER=DriveFlow

# Signature provider configuration
# SIGNATURE_PROVIDER=internal|yousign|docusign|adobe
# internal: OTP demo — allowed only in SIGNATURE_INTERNAL_ENVIRONMENTS unless SIGNATURE_ALLOW_INTERNAL_OUTSIDE_DEV=true
SIGNATURE_PROVIDER=yousign
SIGNATURE_ALLOW_INTERNAL_OUTSIDE_DEV=false
SIGNATURE_INTERNAL_ENVIRONMENTS=local,testing,staging
SIGNATURE_INTERNAL_OTP_LOG=false
# Global webhook HMAC fallback if per-provider secret is empty
SIGNATURE_WEBHOOK_SECRET=
SIGNATURE_CALLBACK_URL="${APP_URL}/api/v1/signatures/webhooks/provider"
SIGNATURE_DOCUMENT_DISK=local
YOUSIGN_BASE_URL=https://api.yousign.app/v3
YOUSIGN_API_KEY=
YOUSIGN_WEBHOOK_SECRET=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_API_KEY=
DOCUSIGN_WEBHOOK_SECRET=

# AI assistant/predictions provider (optional)
AI_PROVIDER_ENABLED=false
AI_PROVIDER_NAME=external
AI_PROVIDER_API_KEY=
